# ============================================================
# Backend (FastAPI) — local dev environment variables
# Copy this file to `.env` and fill in real values.
#
# Storage and Cosmos use AAD (DefaultAzureCredential):
#   - locally: your `az login` identity (needs RBAC, see docs/deployment.md)
#   - in ACA: the Container App's system-assigned managed identity
# Azure OpenAI keeps API-key auth so it can live in another subscription.
# ============================================================

# --- API security ---
# Caller must send this in `X-API-Key` header.
BACKEND_API_KEY=change-me-local-dev-key

# --- Azure OpenAI (pre-deployed) ---
# A separate Azure OpenAI resource with `gpt-5.4` (or `gpt-5.5`) and
# `gpt-image-2` deployments must already exist. We do NOT create them in IaC.
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-aoai-key>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2

# --- Azure Blob Storage (AAD) ---
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account-name>
BLOB_CONTAINER_NAME=studio
SAS_TTL_MINUTES=15

# --- Azure Cosmos DB (NoSQL, AAD) ---
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE_NAME=studio
COSMOS_CONTAINER_NAME=sessions

# --- App ---
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for local dev. In production
# the SWA Linked Backend proxy makes CORS unnecessary.
CORS_ORIGINS=http://localhost:5173
