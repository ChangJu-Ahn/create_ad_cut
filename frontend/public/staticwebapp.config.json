{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": ["/api/*", "/assets/*", "/*.{css,js,png,jpg,jpeg,svg,ico,webp,woff,woff2}"]
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": ["anonymous"]
        }
    ],
    "responseOverrides": {
        "401": { "rewrite": "/index.html", "statusCode": 200 },
        "404": { "rewrite": "/index.html", "statusCode": 200 }
    }
}
